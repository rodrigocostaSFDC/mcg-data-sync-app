                    </argLine>
                </configuration>
            </plugin>
            <!-- Failsafe Plugin: Run Integration Tests -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <version>3.5.3</version>
            </plugin>
            <!-- Spring Boot Maven Plugin for packaging executable JARs -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <includeSystemScope>true</includeSystemScope>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>
            <!-- JaCoCo Plugin: Code Coverage Reporting and Enforcement -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.11</version>
                <configuration>
                    <!-- Require at least 75% instruction coverage on the code base -->
                    <includes>
                        <include>**/launcher/FileDiscoveryResult.class</include>
                        <include>**/helper/DateFormatterHelper.class</include>
                        <include>**/newbatch/data/Operator.class</include>
                        <include>**/batch/shorturlexport/ShortUrlExportTasklet.class</include>
                        <include>**/batch/shorturlexport/ShortUrlExportTasklet$*.class</include>
                    </includes>
                    <rules>
                        <rule>
                            <element>BUNDLE</element>
                            <limits>
                                <limit>
                                    <counter>INSTRUCTION</counter>
                                    <value>COVEREDRATIO</value>
                                    <minimum>0.70</minimum>
                                </limit>
                            </limits>
                        </rule>
                    </rules>
                    <excludes>
                        <!-- Exclude Application bootstrap and constants from coverage -->
                        <exclude>**/*Application.class</exclude>
                        <exclude>**/*Application$*.class</exclude>
                        <exclude>**/constants/**</exclude>
                        <exclude>**/Constants*.class</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>report</goal>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
